{
	"name": "youtumate",
	"productName": "Youtumate",
	"description": "Youtube Views Automation",
	"author": "Ridho Tamma",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "dist-electron/main.cjs",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"format": "biome format --write .",
		"pack": "bun run build && electron-builder --dir",
		"dist": "bun run build && electron-builder --mac --win"
	},
	"build": {
		"appId": "com.youtumate.app",
		"productName": "Youtumate",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist",
			"dist-electron"
		],
		"mac": {
			"icon": "build/icon.icns",
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				}
			]
		},
		"win": {
			"icon": "build/icon.png",
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64",
						"ia32"
					]
				}
			]
		}
	},
	"dependencies": {
		"@primevue/forms": "^4.5.5",
		"@primevue/themes": "^4.5.4",
		"appwrite": "^26.0.0",
		"pinia": "^3.0.4",
		"pinia-plugin-persistedstate": "^4.7.1",
		"primeicons": "^7.0.0",
		"primevue": "^4.5.5",
		"user-agents": "^2.1.93",
		"vue": "^3.5.34",
		"vue-i18n": "^9.14.5",
		"vue-router": "4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@vitejs/plugin-vue": "^6.0.6",
		"electron": "^42.4.0",
		"electron-builder": "^26.15.3",
		"electron-vite": "^5.0.0",
		"javascript-obfuscator": "^5.4.3",
		"puppeteer": "^25.1.0",
		"vite": "^8.0.12",
		"vite-plugin-javascript-obfuscator": "^3.1.0"
	}
}